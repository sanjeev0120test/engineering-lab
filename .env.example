# Copy to `.env` in the repo root (gitignored). Load with your shell or direnv.
# Never commit `.env`, `.env.*`, or real `.tfvars`.

# --- AWS (optional; prefer IAM roles, SSO, or ~/.aws outside this repo) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=

# --- Terraform variables (alternative to terraform.tfvars; also gitignored) ---
# export TF_VAR_name="value"   # Linux/macOS/Git Bash
# $env:TF_VAR_name = "value"   # PowerShell

# --- GitHub API (local only; prefer `gh auth login` + Git Credential Manager) ---
# GH_TOKEN=
